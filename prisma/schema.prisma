generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores    Store[]
  users     User[]
  categories Category[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Store {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  theme         String   @default("default")
  logoUrl         String?
  faviconUrl      String?
  description     String?  @db.Text
  contactEmail    String?
  contactPhone    String?
  contactPhoneIsWhatsApp Boolean @default(false)
  paymentMethods  String?  @db.Text
  deliveryType    String?  @default("pickup")
  deliveryFee     Decimal? @db.Decimal(10, 2)
  deliveryDays    Int?
  addressStreet   String?
  addressNumber   String?
  addressComplement String?
  addressNeighborhood String?
  addressCity     String?
  addressState    String?
  addressZipCode  String?
  tenantId        String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  products Product[]
  orders   Order[]
  customers Customer[]
  cart     Cart[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?  @db.Text
  imageUrl    String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  variations  String[] @default([])
  sizes       String[] @default([])
  tenantId    String
  storeId     String
  categoryId  String?
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cartItems   CartItem[]
  orderItems  OrderItem[]

  @@unique([tenantId, storeId, slug])
  @@index([tenantId])
  @@index([storeId])
  @@index([categoryId])
}

model Customer {
  id       String  @id @default(cuid())
  email   String
  name    String?
  tenantId String
  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([tenantId])
  @@index([storeId])
}

model Order {
  id         String      @id @default(cuid())
  tenantId   String
  storeId    String
  customerId String?
  store      Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  customer   Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  status     String      @default("pending")
  total      Decimal     @db.Decimal(10, 2)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  items OrderItem[]

  @@index([tenantId])
  @@index([storeId])
}

model OrderItem {
  id        String   @id @default(cuid())
  productId String
  quantity  Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)
  variation String   @default("")
  size      String   @default("")
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

model Cart {
  id        String     @id @default(cuid())
  tenantId  String
  storeId   String
  store     Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  items CartItem[]

  @@index([tenantId])
  @@index([storeId])
}

model CartItem {
  id        String   @id @default(cuid())
  productId String
  quantity  Int      @default(1)
  variation String   @default("")
  size      String   @default("")
  cartId    String
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId, variation, size])
  @@index([cartId])
  @@index([productId])
}
