DATABASE_URL=postgresql://user:password@localhost:5432/dbname
# Obrigatório em produção; em dev usa fallback automático
# JWT_SECRET=sua-chave-secreta-longa-e-aleatoria

# Email (Resend) - opcional; sem chave, notificações são ignoradas
# RESEND_API_KEY=re_xxx
# EMAIL_FROM="Minha Loja <noreply@seudominio.com>"

# Upload de imagens (Vercel Blob) - obrigatório para enviar logo/favicon/imagem de produto
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
